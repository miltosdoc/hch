# HCH Environment Configuration
# Copy this file to .env and fill in the values

# Secret key for session encryption — REQUIRED
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=HCH_SECRET_CHANGE_ME

# Default admin credentials — REQUIRED after first setup
# The first admin account is created automatically on app startup
# if no users exist in the database
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME

# WebDoc API credentials (optional — needed for WebDoc sync feature)
WEBDOC_CLIENT_ID=
WEBDOC_CLIENT_SECRET=
